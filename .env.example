# Repmi environment template — copy to `.env` and fill in real values.
# `.env` itself is gitignored; never commit secrets.
#
# Supabase project credentials.
#  - URL: https://<project-ref>.supabase.co
#  - anon/publishable key: from Supabase dashboard → Settings → API
#
# Both are PUBLIC by design (RLS is the access boundary), but DO NOT
# paste the `service_role` key into this app — that key bypasses RLS
# entirely and must only live on a server you control.
EXPO_PUBLIC_SUPABASE_URL=your-supabase-url-here
EXPO_PUBLIC_SUPABASE_ANON_KEY=your-supabase-publishable-anon-key-here

# Sentry crash-reporting DSN (M1). Required only for production builds —
# leaving this blank in dev causes Sentry to be a no-op. The user must
# also opt-in via Settings → Privacy → "Help improve Repmi by sending
# crash reports" before any event is sent, regardless of whether this
# value is set.
EXPO_PUBLIC_SENTRY_DSN=your-sentry-dsn-here

# Demo account — when both are set, a "Try the demo" button appears on
# LoginScreen that one-click signs in as this account. Use a shared,
# pre-seeded account for portfolio demos. Leave blank to hide the button.
EXPO_PUBLIC_DEMO_EMAIL=
EXPO_PUBLIC_DEMO_PASSWORD=
